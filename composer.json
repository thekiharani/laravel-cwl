{
    "name": "norialabs/laravel-cwl",
    "description": "AWS CloudWatch log driver for Laravel. Drop-in replacement — just switch LOG_CHANNEL=cloudwatch.",
    "keywords": ["laravel", "cloudwatch", "logging", "aws", "monolog"],
    "license": "MIT",
    "authors": [
        {
            "name": "Noria Labs",
            "email": "dev@norialabs.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "aws/aws-sdk-php": "^3.0",
        "illuminate/log": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "NoriaLabs\\CloudWatch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NoriaLabs\\CloudWatch\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NoriaLabs\\CloudWatch\\CloudWatchServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
